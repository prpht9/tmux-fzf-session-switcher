#!/usr/bin/env bash

SOURCE=${BASH_SOURCE[0]}
while [ -L "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
  DIR=$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )
  SOURCE=$(readlink "$SOURCE")
  [[ $SOURCE != /* ]] && SOURCE=$DIR/$SOURCE # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
done
CURRENT_DIR=$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )

source $CURRENT_DIR/../env.sh

repo_path=$(get_tmux_option "@tfss_repo_path" "$default_repo_path")
session_launcher=$(get_tmux_option "@tfss_session_launcher" "$default_session_launcher")

pane_path="${TFSS_PANE_PATH:-$(tmux display-message -p '#{pane_current_path}' 2>/dev/null)}"
bare_dir=$(git -C "$pane_path" rev-parse --git-common-dir 2>/dev/null)
worktree_root=$(git -C "$pane_path" rev-parse --show-toplevel 2>/dev/null)
in_bare_worktree=0
if [[ -n $bare_dir && $bare_dir =~ \.bare/?$ ]]; then
  in_bare_worktree=1
fi

menu="New Repo (n), Bare Clone (b), Clone (c), Worktree (w), Jira Worktree (j) or Prefix (p)"
if [[ $in_bare_worktree -eq 1 ]]; then
  menu="${menu} or Delete Worktree (d)"
fi
read -n1 -r -p "${menu}? " flow_choice
echo
if [[ -z $flow_choice ]]; then
  exit 0
fi

session_dir='' # setting variable outside of case scope for use later

case $flow_choice in
  n) # create a new normal empty repo
    read -r -p "New Repo Location: ${repo_path}/" repo_loc
    if [[ -z $repo_loc ]]; then
      echo "Must Enter a New Repo Location"
      exit 1
    fi
    session_dir="${repo_path}/${repo_loc}"
    mkdir -p "${session_dir}"
    git init "${session_dir}"
    ;;

  b) # clone a bare repo
    read -r -p "Bare Repo URL: " repo_url
    if [[ -z $repo_url ]]; then
      echo "Must Enter a Bare Repo URL"
      exit 1
    fi
    read -r -p "New Bare Repo Location: ${HOME}/" repo_loc
    if [[ -z $repo_loc ]]; then
      echo "Must Enter a Bare Repo Location"
      exit 1
    fi
    bare_dir="${HOME}/${repo_loc}"
    parent_dir=$(dirname "$bare_dir")
    mkdir -p "${parent_dir}"
    git clone --bare "${repo_url}" "${bare_dir}"
    read -r -p "Worktree prefix (e.g., mp) [none]: " prefix
    if [[ -n $prefix ]]; then
      git -C "$bare_dir" config --local tfss.prefix "$prefix"
    fi
    if [[ -n $prefix ]]; then
      read_prefilled session_dir "New worktree: " "${parent_dir}/${prefix}-"
    else
      read_prefilled session_dir "New worktree: " "${parent_dir}/"
    fi
    if [[ -z $session_dir || $session_dir == "${parent_dir}/" || $session_dir == "${parent_dir}/${prefix}-" ]]; then
      echo "Must Enter a New Worktree Name"
      exit 1
    fi
    git -C "$bare_dir" worktree add "$session_dir"
    ;;

  c) # clone a normal repo
    read -r -p "Clone Repo URL: " repo_url
    if [[ -z $repo_url ]]; then
      echo "Must Enter a Repo URL"
      exit 1
    fi
    read -r -p "New Repo Location: ${HOME}/" repo_loc
    if [[ -z $repo_loc ]]; then
      echo "Must Enter a Repo Location"
      exit 1
    fi
    clone_dir="${HOME}/${repo_loc}"
    parent_dir=$(dirname "$clone_dir")
    session_dir="${clone_dir}"
    mkdir -p "${parent_dir}"
    git clone "${repo_url}" "${clone_dir}"
    ;;

  w) # create worktree from fzf of bare repo
    if [[ $# -eq 1 ]] ; then
      bare_dir=$1
    else
      bare_dir=$(fd --type d --max-depth 4 '\.bare$' "$repo_path" | ${TFSS_FZF_CMD:-fzf-tmux --reverse})
    fi
    if [[ -z $bare_dir ]]; then
      echo "Must Select a Bare Repo"
      exit 1
    fi
    parent_dir=$(dirname "$bare_dir")
    prefix=$(get_bare_repo_prefix "$bare_dir")
    if [[ -z $prefix ]]; then
      bare_name=$(basename "$bare_dir" .bare)
      echo "No tfss.prefix set for $(basename "$bare_dir")."
      echo "A prefix is a distinct 2-4 char short form of '${bare_name}'"
      echo "  e.g., 'mp' for myproject, 'da' for data-api, 'dot' for dotfiles"
      read -r -p "Set prefix [2-4 chars or Enter to skip]: " new_prefix
      if [[ -n $new_prefix ]]; then
        git -C "$bare_dir" config --local tfss.prefix "$new_prefix"
        prefix="$new_prefix"
      fi
    fi
    if [[ -n $prefix ]]; then
      read_prefilled session_dir "New worktree: " "${parent_dir}/${prefix}-"
    else
      read_prefilled session_dir "New worktree: " "${parent_dir}/"
    fi
    if [[ -z $session_dir || $session_dir == "${parent_dir}/" || $session_dir == "${parent_dir}/${prefix}-" ]]; then
      echo "Must Enter a Worktree Name"
      exit 1
    fi
    mkdir -p "${parent_dir}"
    git -C "$bare_dir" worktree add "$session_dir"
    ;;

  j) # create a jira-style worktree at ../{prefix}/{name}-{jira_id}
    if [[ $in_bare_worktree -eq 1 ]]; then
      : # bare_dir already set at top of script
    else
      bare_dir=$(fd --type d --max-depth 4 '\.bare$' "$repo_path" | ${TFSS_FZF_CMD:-fzf-tmux --reverse})
    fi
    if [[ -z $bare_dir ]]; then
      echo "Must Select a Bare Repo"
      exit 1
    fi
    parent_dir=$(dirname "$bare_dir")
    prefix=$(get_bare_repo_prefix "$bare_dir")
    if [[ -z $prefix ]]; then
      bare_name=$(basename "$bare_dir" .bare)
      echo "No tfss.prefix set for $(basename "$bare_dir")."
      echo "A prefix is a distinct 2-4 char short form of '${bare_name}'"
      echo "  e.g., 'mp' for myproject, 'da' for data-api, 'dot' for dotfiles"
      read -r -p "Set prefix [2-4 chars or Enter to skip]: " new_prefix
      if [[ -n $new_prefix ]]; then
        git -C "$bare_dir" config --local tfss.prefix "$new_prefix"
        prefix="$new_prefix"
      fi
    fi
    if [[ -z $prefix ]]; then
      echo "A prefix is required for Jira worktrees"
      exit 1
    fi
    jira_dir="${parent_dir}/${prefix}"
    echo
    echo "Bare repo:  $bare_dir"
    echo "Jira dir:   ${jira_dir}/"
    echo
    read -r -p "Jira ID: " jira_id
    if [[ -z $jira_id ]]; then
      echo "Must Enter a Jira ID"
      exit 1
    fi
    read -r -p "Worktree name: " worktree_name
    if [[ -z $worktree_name ]]; then
      echo "Must Enter a Worktree Name"
      exit 1
    fi
    session_dir="${jira_dir}/${worktree_name}-${jira_id}"
    mkdir -p "${jira_dir}"
    git -C "$bare_dir" worktree add "$session_dir"
    ;;

  p) # set prefix on existing bare repo
    bare_dir=$(fd --type d --max-depth 4 '\.bare$' "$repo_path" | ${TFSS_FZF_CMD:-fzf-tmux --reverse})
    if [[ -z $bare_dir ]]; then
      echo "Must Select a Bare Repo"
      exit 1
    fi
    current=$(get_bare_repo_prefix "$bare_dir")
    if [[ -n $current ]]; then
      echo "Current prefix: ${current}"
    fi
    read -r -p "Enter prefix: " new_prefix
    if [[ -z $new_prefix ]]; then
      echo "Must Enter a Prefix"
      exit 1
    fi
    git -C "$bare_dir" config --local tfss.prefix "$new_prefix"
    echo "Prefix set to '${new_prefix}' for $(basename "$bare_dir")"
    exit 0
    ;;

  d) # delete current bare-repo worktree and its tmux session
    current_session="${TFSS_CURRENT_SESSION:-$(tmux display-message -p '#S' 2>/dev/null)}"

    echo
    echo "Bare repo:  $bare_dir"
    echo "Worktree:   $worktree_root"
    echo
    read -r -p 'Type "Yes" to confirm deletion [N]: ' confirm
    if [[ $confirm != "Yes" ]]; then
      exit 0
    fi

    session_count=$(tmux list-sessions 2>/dev/null | wc -l | tr -d ' ')
    if [[ $session_count -le 1 ]]; then
      echo "Cannot delete: no other session to switch to"
      exit 1
    fi

    if ! git -C "$bare_dir" worktree remove "$worktree_root"; then
      exit 1
    fi

    if [[ -n $TMUX ]]; then
      tmux switch-client -l
    fi
    tmux kill-session -t "$current_session"
    exit 0
    ;;

  *)
    echo "Repo Command Invalid"
    exit 1
    ;;
esac

session=$(basename "$session_dir" | tr . _)
if ! tmux ls 2>/dev/null; then
  tmux start-server
fi

if tmux has-session -t="${session}" 2> /dev/null; then
  if [ -z "$TMUX" ] ; then
    tmux attach-session -t "${session}"
  else
    tmux switch-client -t "${session}"
    exit
  fi
else
  tmux new-session -ds "$session" -c "$session_dir" -n "localhost"
  eval "$session_launcher $session $session_dir"
fi

